---
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);
---
<section class="section" id="faq">
  <div class="container">
    <div class="heading">
      <p class="eyebrow">{t.faq.eyebrow}</p>
      <h2>{t.faq.title}</h2>
    </div>

    <ul class="faq-list" role="list">
      {t.faq.items.map((it) => (
        <li>
          <details class="faq-item">
            <summary class="faq-q">
              <span>{it.q}</span>
              <svg class="faq-chevron" width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 6l4 4 4-4"/></svg>
            </summary>
            <p class="faq-a">{it.a}</p>
          </details>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .section {
    position: relative;
    padding: var(--space-32) 0;
    border-top: 1px solid var(--color-border);
  }

  .heading {
    margin-bottom: var(--space-12);
  }

  h2 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    line-height: 1.1;
    color: var(--color-ink);
  }

  .faq-list {
    max-width: 760px;
  }

  .faq-item {
    border-bottom: 1px solid var(--color-border);
  }

  .faq-q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    padding: var(--space-6) 0;
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-ink);
    cursor: pointer;
    list-style: none;
  }
  .faq-q::-webkit-details-marker { display: none; }

  .faq-chevron {
    flex-shrink: 0;
    color: var(--color-muted);
    transition: transform var(--transition-base), color var(--transition-base);
  }
  .faq-item[open] .faq-chevron {
    transform: rotate(180deg);
    color: var(--color-primary);
  }

  .faq-a {
    padding: 0 0 var(--space-6);
    max-width: 64ch;
    font-size: var(--text-base);
    color: var(--color-muted);
    line-height: 1.7;
  }
</style>
