---
const steps = [
  {
    number: '01',
    title: 'Start the proxy',
    description: 'Veil runs a local proxy on your machine. Nothing leaves without going through it.',
    code: 'veil proxy --addr 127.0.0.1:8788',
  },
  {
    number: '02',
    title: 'Point your agent at it',
    description: 'Set one environment variable. Claude Code, Codex, and any OpenAI-compatible tool work out of the box.',
    code: 'export ANTHROPIC_BASE_URL=http://127.0.0.1:8788',
  },
  {
    number: '03',
    title: 'Work freely',
    description: 'Veil masks secrets on the way out and restores real values in every response. The model sees only tokens.',
    code: null,
  },
];
---
<section class="section" id="how-it-works">
  <div class="container">
    <h2>How it works</h2>
    <p class="section-sub">
      Three steps. No config files. No changes to your workflow.
    </p>
    <ol class="steps" role="list">
      {steps.map((step) => (
        <li class="step">
          <span class="step-number" aria-hidden="true">{step.number}</span>
          <div class="step-body">
            <h3>{step.title}</h3>
            <p>{step.description}</p>
            {step.code && (
              <pre class="step-code"><code>{step.code}</code></pre>
            )}
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .section {
    padding: var(--space-24) 0;
    border-top: 1px solid var(--color-border);
  }

  .section-sub {
    font-size: var(--text-lg);
    color: var(--color-muted);
    margin-top: var(--space-4);
    margin-bottom: var(--space-16);
    max-width: 48ch;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-8);
  }

  .step {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .step-number {
    font-size: var(--text-xs);
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-primary-dark);
  }

  .step-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .step-body p {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.7;
  }

  .step-code {
    background: var(--color-dark);
    color: var(--color-code-text);
    font-size: var(--text-xs);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    overflow-x: auto;
    white-space: pre;
  }

  @media (max-width: 768px) {
    .steps {
      grid-template-columns: 1fr;
      gap: var(--space-10);
    }
  }
</style>
