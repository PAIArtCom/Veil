---
import Logo from './Logo.astro';
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer-inner">
      <Logo size={24} />
      <p class="footer-copy">
        © {year} Veil contributors. Apache-2.0.
      </p>
      <nav class="footer-links" aria-label="Footer navigation">
        <a href="https://github.com/PAIArtCom/Veil" target="_blank" rel="noopener noreferrer">
          GitHub
        </a>
        <a href="https://github.com/PAIArtCom/Veil/releases" target="_blank" rel="noopener noreferrer">
          Releases
        </a>
        <a href="https://github.com/PAIArtCom/Veil/blob/main/SECURITY.md" target="_blank" rel="noopener noreferrer">
          Security
        </a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-10) 0;
    margin-top: var(--space-24);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .footer-copy {
    font-size: var(--text-sm);
    color: var(--color-subtle);
    margin-right: auto;
  }

  .footer-links {
    display: flex;
    gap: var(--space-5);
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .footer-links a:hover {
    color: var(--color-ink);
  }
</style>
