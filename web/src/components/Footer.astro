---
import Logo from './Logo.astro';
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);
const year = new Date().getFullYear();
---
<footer class="footer">
  <div class="container">
    <div class="footer-divider"></div>
    <div class="footer-inner">
      <div class="footer-brand">
        <Logo size={22} />
        <p class="footer-copy">
          &copy; {year} {t.footer.copyright}
        </p>
      </div>
      <nav class="footer-links" aria-label={t.a11y.footerNav}>
        <a href="https://github.com/PAIArtCom/Veil" target="_blank" rel="noopener noreferrer">
          {t.footer.github}
        </a>
        <a href="https://github.com/PAIArtCom/Veil/releases" target="_blank" rel="noopener noreferrer">
          {t.footer.releases}
        </a>
        <a href="https://github.com/PAIArtCom/Veil/blob/main/SECURITY.md" target="_blank" rel="noopener noreferrer">
          {t.footer.security}
        </a>
      </nav>
    </div>
  </div>
</footer>

<style>
  .footer {
    padding: var(--space-16) 0 var(--space-10);
    margin-top: var(--space-16);
  }

  .footer-divider {
    height: 1px;
    background: var(--color-border);
    margin-bottom: var(--space-10);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-6);
  }

  .footer-brand {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .footer-copy {
    font-size: var(--text-sm);
    color: var(--color-muted);
  }

  .footer-links {
    display: flex;
    gap: var(--space-6);
    font-size: var(--text-sm);
  }

  .footer-links a {
    color: var(--color-muted);
    transition: color var(--transition-fast);
  }

  .footer-links a:hover {
    color: var(--color-ink);
  }
</style>
