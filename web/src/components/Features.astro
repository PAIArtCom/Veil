---
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);

// Lucide icons (ISC-licensed), one per card, matched to each card's meaning:
// detection · stable mapping · blocking · local process.
const icons = [
  '<path d="M3 7V5a2 2 0 0 1 2-2h2"/><path d="M17 3h2a2 2 0 0 1 2 2v2"/><path d="M21 17v2a2 2 0 0 1-2 2h-2"/><path d="M7 21H5a2 2 0 0 1-2-2v-2"/><circle cx="12" cy="12" r="3"/><path d="m16 16-1.9-1.9"/>',
  '<path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>',
  '<circle cx="12" cy="12" r="10"/><path d="m4.9 4.9 14.2 14.2"/>',
  '<rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/>',
];
---
<section class="section" id="features">
  <div class="container">
    <div class="section-heading">
      <div class="heading-content">
        <p class="eyebrow">{t.features.eyebrow}</p>
        <h2>{t.features.title} <em>{t.features.titleAccent}</em></h2>
        <p class="section-sub">{t.features.sub}</p>
      </div>
      <a href="#install" class="section-link">
        {t.features.link}
        <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="link-arrow"><path d="M5 12l7-7m0 0v6m0-6H6"/></svg>
      </a>
    </div>

    <ul class="features" role="list">
      {t.features.cards.map((f, i) => (
        <li class="feature-card">
          <div class="feature-header">
            <span class="feature-icon" aria-hidden="true">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[i]} />
            </span>
            <p class="problem">{f.problem}</p>
          </div>
          <h3 class="feature-title">{f.title}</h3>
          <p class="feature-desc">{f.description}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .section {
    position: relative;
    padding: var(--space-32) 0;
  }

  .section-heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-8);
    margin-bottom: var(--space-20);
  }

  @media (min-width: 1024px) {
    .section-heading {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
    .heading-content {
      max-width: 60%;
    }
  }


  h2 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    line-height: 1.1;
    margin-bottom: var(--space-6);
    color: var(--color-ink);
  }


  .section-sub {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.6;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-ink);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-3) var(--space-6);
    background: var(--fill-hover);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    transition: background var(--transition-base), border-color var(--transition-base);
  }

  .section-link:hover {
    background: var(--line);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .link-arrow {
    transition: transform var(--transition-fast);
  }

  .section-link:hover .link-arrow {
    transform: translate(2px, -2px);
    stroke: var(--color-primary);
  }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-6);
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: border-color var(--transition-base);
  }

  .feature-card:hover {
    border-color: var(--color-border-strong);
  }

  .feature-header {
    margin-bottom: var(--space-6);
  }

  .feature-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    background: var(--tint-primary);
    border: 1px solid var(--tint-primary-strong);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  /* A quiet category label, not a red alarm pill */
  .problem {
    display: inline-block;
    color: var(--color-muted);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .feature-title {
    font-size: var(--text-xl);
    color: var(--color-ink);
    margin-bottom: var(--space-3);
    font-weight: 600;
  }

  .feature-desc {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.7;
    margin-top: auto;
  }
</style>
