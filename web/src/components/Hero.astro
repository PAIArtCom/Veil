---
import ProxyTraceDemo from './ProxyTraceDemo.astro';
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);
---
<section class="hero">
  <div class="container hero-grid">
    <div class="hero-body">
      <div class="badge">
        <span class="badge-dot"></span>
        {t.hero.badge}
      </div>
      <h1>{t.hero.title} <em>{t.hero.titleAccent}</em></h1>
      <p class="sub">{t.hero.sub}</p>
      <div class="actions">
        <a href="#install" class="btn btn-primary">
          <span class="btn-inner">{t.hero.cta}</span>
        </a>
        <a
          href="https://github.com/PAIArtCom/Veil"
          class="btn btn-secondary"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t.hero.github}
        </a>
      </div>
      <ul class="hero-proof" role="list">
        <li>
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8l4 4 8-8"/></svg>
          {t.hero.proofLocal}
        </li>
        <li>
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8l4 4 8-8"/></svg>
          {t.hero.proofNoCloud}
        </li>
        <li>
          <svg viewBox="0 0 16 16" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 8l4 4 8-8"/></svg>
          {t.hero.proofLicense}
        </li>
      </ul>
    </div>
    <div class="hero-demo">
      <ProxyTraceDemo />
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-32) 0 var(--space-20);
    overflow: hidden;
  }

  .hero-grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.86fr) minmax(480px, 1.14fr);
    align-items: center;
    gap: var(--space-16);
  }

  .hero-body {
    max-width: var(--max-width-prose);
  }

  .badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-ink);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    padding: var(--space-1) var(--space-3) var(--space-1) var(--space-2);
    border-radius: var(--radius-pill);
    margin-bottom: var(--space-8);
  }

  .badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--color-primary);
  }

  h1 {
    font-size: clamp(var(--text-4xl), 6vw, 4.5rem);
    line-height: 1.05;
    letter-spacing: -0.04em;
    margin-bottom: var(--space-6);
    color: var(--color-ink);
    text-wrap: balance;
  }

  h1 em {
    display: block;
    font-style: normal;
    color: var(--color-primary);
  }

  .sub {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 52ch;
    margin-bottom: var(--space-8);
  }

  .actions {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-bottom: var(--space-10);
  }

  .hero-proof {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    color: var(--color-muted);
    font-size: var(--text-sm);
  }

  .hero-proof li {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .hero-proof svg {
    color: var(--color-primary);
  }

  @media (max-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-12);
    }
  }
</style>
