---
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);
---
<section class="section trust" id="trust">
  <div class="container trust-grid">
    <div class="trust-copy">
      <p class="eyebrow">{t.trust.eyebrow}</p>
      <h2>{t.trust.title} <em>{t.trust.titleAccent}</em> {t.trust.titleEnd}</h2>
      <p class="section-sub">{t.trust.sub}</p>
      <div class="trust-actions">
        <a
          class="btn btn-primary"
          href="https://github.com/PAIArtCom/Veil/blob/main/docs/architecture/threat-model.md"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t.trust.ctaThreat}
        </a>
        <a
          class="btn btn-secondary"
          href="https://github.com/PAIArtCom/Veil/tree/main/docs/architecture"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t.trust.ctaArch}
        </a>
      </div>
    </div>
    <ul class="guarantees" role="list">
      {t.trust.cards.map((item) => (
        <li class="guarantee-card">
          <div class="guarantee-icon" aria-hidden="true">
            {item.id === 'shield' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                <path d="M9 12l2 2 4-4" opacity="0.6"/>
              </svg>
            )}
            {item.id === 'lock' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                <circle cx="12" cy="16" r="1" fill="currentColor" stroke="none"/>
              </svg>
            )}
            {item.id === 'arrows' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M8 3L4 7l4 4"/>
                <path d="M4 7h16"/>
                <path d="M16 21l4-4-4-4"/>
                <path d="M20 17H4"/>
              </svg>
            )}
            {item.id === 'eye' && (
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/>
                <circle cx="12" cy="12" r="3"/>
              </svg>
            )}
          </div>
          <div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .section {
    position: relative;
    padding: var(--space-32) 0;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.82fr) minmax(0, 1.18fr);
    gap: var(--space-12);
    align-items: start;
  }


  h2 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    line-height: 1.1;
    margin-bottom: var(--space-6);
    color: var(--color-ink);
  }


  .section-sub {
    color: var(--color-muted);
    font-size: var(--text-lg);
    line-height: 1.7;
    margin-top: var(--space-4);
    max-width: 48ch;
  }

  .trust-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .guarantees {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-4);
  }

  .guarantee-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-6);
    transition: border-color var(--transition-base);
  }

  .guarantee-card:hover {
    border-color: var(--color-border-strong);
  }

  .guarantee-icon {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    background: rgba(43, 191, 126, 0.12);
    border: 1px solid rgba(43, 191, 126, 0.25);
    color: var(--color-primary);
  }

  .guarantee-icon svg {
    flex-shrink: 0;
  }

  .guarantees h3 {
    color: var(--color-ink);
    font-size: var(--text-lg);
    font-weight: 600;
    margin-bottom: var(--space-3);
  }

  .guarantees p {
    color: var(--color-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  @media (max-width: 1024px) {
    .trust-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .guarantees {
      grid-template-columns: 1fr;
    }
  }
</style>
