---
import { useTranslations } from '../i18n';

const t = useTranslations(Astro.currentLocale);

const copyIcon = `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>`;
---
<section class="section" id="install">
  <div class="container">
    <div class="install-heading">
      <div class="heading-content">
        <p class="eyebrow">{t.install.eyebrow}</p>
        <h2>{t.install.title} <em>{t.install.titleAccent}</em> {t.install.titleEnd}</h2>
        <p class="section-sub">{t.install.sub}</p>
      </div>
      <a
        class="section-link"
        href="https://github.com/PAIArtCom/Veil/releases/latest"
        target="_blank"
        rel="noopener noreferrer"
      >
        {t.install.link}
        <svg viewBox="0 0 16 16" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="link-arrow"><path d="M5 12l7-7m0 0v6m0-6H6"/></svg>
      </a>
    </div>

    <!-- One-liner install methods -->
    <div class="methods-grid">
      <div class="method-card">
        <div class="method-header">
          <span class="method-label">{t.install.curl.label}</span>
          <span class="method-hint">{t.install.curl.hint}</span>
        </div>
        <div class="code-window">
          <div class="window-header">
            <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
            <span class="window-title">sh</span>
          </div>
          <pre><code id="cmd-curl">curl -fsSL https://veil.paiart.com/install.sh | sh</code></pre>
          <button type="button" class="copy-btn" data-target="cmd-curl" data-copied={t.install.copied} aria-label="Copy curl install command">
            <Fragment set:html={copyIcon} />
          </button>
        </div>
      </div>

      <div class="method-card">
        <div class="method-header">
          <span class="method-label">{t.install.npm.label}</span>
          <span class="method-hint">{t.install.npm.hint}</span>
        </div>
        <div class="code-window">
          <div class="window-header">
            <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
            <span class="window-title">sh</span>
          </div>
          <pre><code id="cmd-npm">npm install -g @paiart/veil</code></pre>
          <button type="button" class="copy-btn" data-target="cmd-npm" data-copied={t.install.copied} aria-label="Copy npm install command">
            <Fragment set:html={copyIcon} />
          </button>
        </div>
      </div>

      <div class="method-card">
        <div class="method-header">
          <span class="method-label">{t.install.brew.label}</span>
          <span class="method-hint">{t.install.brew.hint}</span>
        </div>
        <div class="code-window">
          <div class="window-header">
            <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
            <span class="window-title">sh</span>
          </div>
          <pre><code id="cmd-brew">brew install PAIArtCom/veil/veil</code></pre>
          <button type="button" class="copy-btn" data-target="cmd-brew" data-copied={t.install.copied} aria-label="Copy Homebrew install command">
            <Fragment set:html={copyIcon} />
          </button>
        </div>
      </div>

      <div class="method-card">
        <div class="method-header">
          <span class="method-label">{t.install.winps.label}</span>
          <span class="method-hint">{t.install.winps.hint}</span>
        </div>
        <div class="code-window">
          <div class="window-header">
            <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
            <span class="window-title">powershell</span>
          </div>
          <pre><code id="cmd-winps">irm https://veil.paiart.com/install.ps1 | iex</code></pre>
          <button type="button" class="copy-btn" data-target="cmd-winps" data-copied={t.install.copied} aria-label="Copy PowerShell install command">
            <Fragment set:html={copyIcon} />
          </button>
        </div>
      </div>
    </div>

    <!-- Divider -->
    <div class="agents-divider">
      <span>{t.install.agentsLabel}</span>
    </div>

    <!-- Agent setup cards -->
    <div class="install-options">
      <div class="install-card">
        <div class="card-header">
          <h3>{t.install.claudeCode.title}</h3>
          <a class="inline-link" href="https://github.com/PAIArtCom/Veil/blob/main/docs/guides/claude-code.md" target="_blank" rel="noopener noreferrer">{t.install.claudeCode.guide} &rarr;</a>
        </div>
        <p>{t.install.claudeCode.description}</p>
        <div class="code-window">
          <div class="window-header">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="window-title">bash</span>
          </div>
          <pre><code id="cmd-claude"><span class="prompt">$</span> veil proxy --addr 127.0.0.1:8788 &
<span class="prompt">$</span> export ANTHROPIC_BASE_URL=http://127.0.0.1:8788
<span class="prompt">$</span> claude</code></pre>
          <button type="button" class="copy-btn" data-target="cmd-claude" data-copied={t.install.copied} aria-label="Copy Claude Code commands">
            <Fragment set:html={copyIcon} />
          </button>
        </div>
      </div>

      <div class="install-card">
        <div class="card-header">
          <h3>{t.install.codex.title}</h3>
          <a class="inline-link" href="https://github.com/PAIArtCom/Veil/blob/main/docs/guides/codex.md" target="_blank" rel="noopener noreferrer">{t.install.codex.guide} &rarr;</a>
        </div>
        <p>{t.install.codex.description}</p>
        <div class="code-window">
          <div class="window-header">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
            <span class="window-title">bash</span>
          </div>
          <pre><code id="cmd-codex"><span class="prompt">$</span> veil proxy --addr 127.0.0.1:8788 --upstream https://api.openai.com
<span class="comment"># ~/.codex/config.toml</span>
model_provider = "veil"</code></pre>
          <button type="button" class="copy-btn" data-target="cmd-codex" data-copied={t.install.copied} aria-label="Copy Codex commands">
            <Fragment set:html={copyIcon} />
          </button>
        </div>
      </div>
    </div>

    <p class="source-note">
      <a href="https://github.com/PAIArtCom/Veil#install" target="_blank" rel="noopener noreferrer">
        {t.install.sourceLink} &rarr;
      </a>
    </p>

    <span class="visually-hidden" role="status" aria-live="polite" data-copy-status></span>
  </div>
</section>

<script>
  import { stripTrailingNewline } from '../scripts/copy-code.js';

  const status = document.querySelector('[data-copy-status]');

  document.querySelectorAll('.copy-btn').forEach((btn) => {
    btn.addEventListener('click', async () => {
      const targetId = btn.getAttribute('data-target');
      const codeEl = document.getElementById(targetId);
      if (!codeEl) return;

      const clone = codeEl.cloneNode(true);
      clone.querySelectorAll('.prompt').forEach(el => el.remove());
      const text = stripTrailingNewline(clone.textContent ?? '');
      const copiedLabel = btn.getAttribute('data-copied') || 'Copied';

      try {
        await navigator.clipboard.writeText(text);
        const originalHTML = btn.innerHTML;
        btn.innerHTML = `<span class="copy-feedback">${copiedLabel}</span>`;
        if (status) status.textContent = copiedLabel;
        setTimeout(() => { btn.innerHTML = originalHTML; if (status) status.textContent = ''; }, 2000);
      } catch {
        if (status) status.textContent = 'Copy failed';
      }
    });
  });
</script>

<style>
  .section {
    position: relative;
    padding: var(--space-32) 0;
    border-top: 1px solid var(--color-border);
  }

  .install-heading {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-8);
    margin-bottom: var(--space-20);
  }

  @media (min-width: 1024px) {
    .install-heading {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
    .heading-content {
      max-width: 60%;
    }
  }

  h2 {
    font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
    line-height: 1.1;
    margin-bottom: var(--space-6);
    color: var(--color-ink);
  }

  .section-sub {
    font-size: var(--text-lg);
    color: var(--color-muted);
    line-height: 1.6;
  }

  .section-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-ink);
    font-size: var(--text-sm);
    font-weight: 600;
    padding: var(--space-3) var(--space-6);
    background: var(--fill-hover);
    border: 1px solid var(--line);
    border-radius: var(--radius-pill);
    transition: background var(--transition-base), border-color var(--transition-base);
    white-space: nowrap;
  }

  .section-link:hover {
    background: var(--line);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .link-arrow {
    transition: transform var(--transition-fast);
  }

  .section-link:hover .link-arrow {
    transform: translate(2px, -2px);
    stroke: var(--color-primary);
  }

  /* ── One-liner methods grid ─────────────────────────────────────────────── */
  .methods-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  .method-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    transition: border-color var(--transition-base);
  }

  .method-card:hover {
    border-color: var(--color-border-strong);
  }

  .method-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
  }

  .method-label {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-ink);
  }

  .method-hint {
    font-size: var(--text-xs);
    color: var(--color-subtle);
    text-align: right;
  }

  /* ── Agents divider ─────────────────────────────────────────────────────── */
  .agents-divider {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    color: var(--color-muted);
    font-size: var(--text-sm);
    font-weight: 500;
  }

  .agents-divider::before,
  .agents-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* ── Agent setup cards ──────────────────────────────────────────────────── */
  .install-options {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: var(--space-6);
    margin-bottom: var(--space-8);
  }

  .install-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    transition: border-color var(--transition-base);
  }

  .install-card:hover {
    border-color: var(--color-border-strong);
  }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .card-header h3 {
    font-size: var(--text-xl);
    color: var(--color-ink);
    font-weight: 600;
  }

  .install-card p {
    font-size: var(--text-sm);
    color: var(--color-muted);
    line-height: 1.6;
    margin-bottom: var(--space-2);
  }

  .inline-link {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .inline-link:hover {
    color: var(--color-ink);
  }

  /* ── Source note ────────────────────────────────────────────────────────── */
  .source-note {
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-subtle);
  }

  .source-note a {
    color: var(--color-muted);
    transition: color var(--transition-fast);
  }

  .source-note a:hover {
    color: var(--color-ink);
  }

  /* ── Code windows (shared) ──────────────────────────────────────────────── */
  .code-window {
    position: relative;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-top: auto;
    overflow: hidden;
  }

  .window-header {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 16px;
    background: var(--fill-faint);
    border-bottom: 1px solid var(--color-border);
  }

  .dot { width: 10px; height: 10px; border-radius: 50%; }
  .dot.red { background: #FF5F56; }
  .dot.yellow { background: #FFBD2E; }
  .dot.green { background: #27C93F; }

  .window-title {
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-subtle);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .code-window pre {
    padding: var(--space-4) var(--space-5);
    margin: 0;
    overflow-x: auto;
  }

  .code-window code {
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.7;
    color: var(--color-ink);
  }

  .prompt {
    color: var(--color-primary);
    user-select: none;
    margin-right: 8px;
  }

  .comment {
    color: var(--color-muted);
  }

  .copy-btn {
    position: absolute;
    bottom: var(--space-3);
    right: var(--space-3);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    background: var(--fill-hover);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    color: var(--color-muted);
    transition: color var(--transition-fast), background var(--transition-fast);
  }

  .copy-btn:hover {
    color: var(--color-ink);
    background: var(--color-primary);
    border-color: var(--color-primary);
  }

  .copy-feedback {
    font-size: 9px;
    font-weight: 600;
    letter-spacing: 0.02em;
    white-space: nowrap;
  }

  .copy-btn:has(.copy-feedback) {
    width: auto;
    padding-inline: var(--space-2);
  }

  @media (max-width: 768px) {
    .methods-grid {
      grid-template-columns: 1fr;
    }
    .install-options {
      grid-template-columns: 1fr;
    }
  }
</style>
